<file path="docker-compose.yml">
# no añadimos versión ya que se usa directamente la última especificaciónd de sintaxis

services:  # se definen los tres contenedores: 'web' para el servidor web, 'db' para base de datos y 'phpma' para la interfaz
  web:
    build: .  # trabajaremos con nuestra propia imagen, '.' es el directorio actual, donde tiene que buscar el Dockerfile
    container_name: bep_web  # nombre del contenedor. 'bep' -> back end productos + nombre contenedor, lo mismo para el resto
    ports:
      - "8080:80"  # 8080 puerto local, 80 puerto del contenedor. cuando accedamos al localhopst:8080, docker lleva el tráfico al puerto 80 del contenedor para acceder a la app desde el navegador
    volumes:
      - ./:/var/www/html  # guardamos el código en la carpeta /src (modificación p2, no solo src, todas las carpetas) y aquí se vincula con la carpeta /var/www/html que está dentro del contenedor (apache lee aquí los archivos). cuando hagamos un cambio en /src se hará también en el servidor web del contenedor
    depends_on:
      - db  # el contenedor 'web' sólo se iniciará cuando el contenedor 'db' esté funcionando

  db:
    image: mysql:8.0
    container_name: bep_db
    restart: always  # reinicio automático del contenedor si falla, para que la bbdd siempre sté en fuincionamiento en segundo plano
    environment:  # variables de entorno para el arranque de la bbdd: crear contraseña root, crear la bbdd llamada 'backend_:ddbb', y el usuario y la contraseña
      MYSQL_ROOT_PASSWORD: rootpassword
      MYSQL_DATABASE: backend_ddbb
      MYSQL_USER: backend_user
      MYSQL_PASSWORD: backend_userpassword
    ports:
      - "3307:3306"  # puerto standard de mysql, para acceder desde local
    volumes:
      - db_data:/var/lib/mysql  # igual que antes pero ahora mapeamos los datos de mysql con 'db_data' para guardarlos en la ruta, así se guardan si se borrara el contenedor ed mysql

  phpma:
    image: phpmyadmin/phpmyadmin
    container_name: bep_phpma
    ports:
      - "8081:80"
    environment:
      PMA_HOST: db # referencia para que phpmyadmin sepa a qué servidor de bbdd debe conectarse, que es el contenedor 'db' -> funciona como un dominio de red de docker
      MYSQL_ROOT_PASSWORD: rootpassword
    depends_on:
      - db

volumes:
  db_data:  # definición del volumen que referenciamos en el contenedor 'db' para guardar los datos de mysql
</file>

<file path="Dockerfile">
# imagen base que ya teníamos, sirve como base para después añadir extensiones
FROM php:8.2-apache  

# módulo de apache para escribir las urls de Laravel más sencillas 
RUN a2enmod rewrite

# hacemos que apache acepte el htaccess
RUN sed -i '/<Directory \/var\/www\/>/,/<\/Directory>/ s/AllowOverride None/AllowOverride All/' /etc/apache2/apache2.conf

# instalamos las extensiones y paquetes para laravel
# git y unzip para descargar y descomprimir librerías
# libzip para que php pueda trabajar con zips
# pdo_mysql para que php pueda trabajar con mysql (driver)
RUN apt-get update && apt-get install -y \
    git \
    unzip \
    libzip-dev \
    && docker-php-ext-install pdo_mysql zip

# copiamos el archivo ejecutable de composer desde la imagen oficial, así se puede usar sin descargar ni instalar
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# hacemos que apache tome los archivos desde la carpeta /public de laravel
ENV APACHE_DOCUMENT_ROOT /var/www/html/public
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf

# le decimos que cuando entremos a un contenedor trabajaremos en la carpeta del servidor web
WORKDIR /var/www/html
</file>

